# ============================================================
# NEXUS OSINT – Umgebungsvariablen (Vorlage)
# ============================================================
# Kopieren: cp .env.example .env
# WICHTIG: .env NIEMALS commiten (steht in .gitignore)
# ============================================================

# ── Server ────────────────────────────────────────────────
NEXUS_PORT=5050
NEXUS_HOST=0.0.0.0

# ── SICHERHEIT (PFLICHT bei netzwerk-exponiertem Server!) ─
# Zufälligen Token erzeugen:
#   python -c "import secrets; print(secrets.token_hex(32))"
NEXUS_TOKEN=HIER_LANGEN_ZUFAELLIGEN_TOKEN_EINTRAGEN

# ── Copernicus / Sentinel-2 ───────────────────────────────
# Registrierung: https://dataspace.copernicus.eu/
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=

# ── ACLED Konfliktdaten ───────────────────────────────────
# Registrierung: https://acleddata.com/register/
ACLED_KEY=
ACLED_EMAIL=

# ── AISStream (Schiffspositionen) ─────────────────────────
# Registrierung: https://aisstream.io/
AISSTREAM_KEY=

# ── Email / SMTP (Tagesbericht) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TO=

# ── Optional ──────────────────────────────────────────────
OPENWEATHER_KEY=
DEEPL_API_KEY=
VK_ACCESS_TOKEN=
